{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: mobile web",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build", "--workspace", "apps/mobile-web"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build: windows host",
      "type": "shell",
      "command": "dotnet",
