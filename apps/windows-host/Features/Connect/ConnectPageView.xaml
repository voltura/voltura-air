<UserControl x:Class="VolturaAir.Host.Features.Connect.ConnectPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:VolturaAir.Host.Ui">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="{DynamicResource GridSpace2xl}" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="{DynamicResource InsetXl}"
                Background="{DynamicResource QrBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource RadiusMedium}">
            <Image x:Name="QrCodeImage"
                   MaxWidth="560"
                   MaxHeight="560"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Stretch="Uniform" />
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{DynamicResource GridSpaceMd}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:SpacingStackPanel Spacing="{DynamicResource SpaceMd}">
                <ui:InfoCard x:Name="StatusCard" Title="Current status" Emphasized="True" />
                <ui:InfoCard x:Name="SelectedAdapterCard" Title="Network adapter" />
                <ui:InfoCard x:Name="PairingCodeCard" Title="QR code">
                    <ui:InfoCard.Actions>
                        <ui:SpacingStackPanel Orientation="Horizontal" Spacing="{DynamicResource SpaceSm}">
                            <Button Content="New code"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Click="OnNewCodeClicked" />
                            <Button Content="Copy link" Click="OnCopyLinkClicked" />
                        </ui:SpacingStackPanel>
                    </ui:InfoCard.Actions>
                </ui:InfoCard>

                <Border x:Name="AddressWarningNotice"
                        Padding="{DynamicResource InsetMd}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Visibility="Collapsed">
                    <TextBlock x:Name="AddressWarningText" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                </Border>

                <Border x:Name="PortWarningNotice"
                        Padding="{DynamicResource InsetMd}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Visibility="Collapsed">
                    <TextBlock x:Name="PortWarningText" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                </Border>
            </ui:SpacingStackPanel>

            <Expander x:Name="DetailsExpander"
                      Grid.Row="2"
                      Header="Details"
                      IsExpanded="False"
                      Style="{DynamicResource BoundedAccordionStyle}">
                <ScrollViewer x:Name="DetailsScroller"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ui:SpacingStackPanel Spacing="{DynamicResource SpaceMd}">
                        <ui:InfoCard x:Name="PairingLinkCard" Title="Pairing link" Monospace="True" />
                        <ui:InfoCard x:Name="HostUrlCard" Title="Host URL" Monospace="True" />
                        <ui:InfoCard x:Name="SelectedIpCard" Title="Selected IP" Monospace="True" />
                        <ui:InfoCard x:Name="SelectedPortCard" Title="Selected port" Monospace="True" />
                    </ui:SpacingStackPanel>
                </ScrollViewer>
            </Expander>
        </Grid>
    </Grid>
</UserControl>
