<UserControl x:Class="VolturaAir.Host.Features.Devices.DevicesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             xmlns:ui="clr-namespace:VolturaAir.Host.Ui">
    <UserControl.Resources>
        <system:Double x:Key="PermissionChoiceButtonWidth">112</system:Double>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="{DynamicResource GridSpaceLg}" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox x:Name="DeviceList"
                 Style="{DynamicResource ModernListBoxStyle}"
                 ItemContainerStyle="{DynamicResource ModernListBoxItemStyle}"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 KeyboardNavigation.TabNavigation="Continue"
                 AutomationProperties.Name="Paired devices"
                 AutomationProperties.HelpText="Press Up or Down Arrow to select a device. Press Enter or Space to expand or collapse it. Press Tab to move through its controls."
                 GotKeyboardFocus="OnDeviceListKeyboardFocus"
                 PreviewKeyDown="OnDeviceListPreviewKeyDown">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Expander x:Name="DeviceAccordion"
                              Header="{Binding}"
                              IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                              Expanded="OnDeviceExpanded"
                              Collapsed="OnDeviceCollapsed"
                              Style="{DynamicResource PreferencesAccordionStyle}">
                        <Expander.HeaderTemplate>
                            <DataTemplate>
                                <ui:SpacingStackPanel Spacing="{DynamicResource SpaceXs}">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <ui:PillBadge x:Name="ConnectionStatusPill"
                                                  Content="{Binding Status}"
                                                  Tone="{Binding StatusTone}" />
                                    <TextBlock Text="{Binding Activity}"
                                               FontSize="12"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </ui:SpacingStackPanel>
                            </DataTemplate>
                        </Expander.HeaderTemplate>
                        <ui:SpacingStackPanel Spacing="{DynamicResource SpaceMd}">
                            <TextBlock Text="{Binding Metadata, TargetNullValue=No device metadata}"
                                       Foreground="{DynamicResource TextBrush}"
                                       TextWrapping="Wrap" />
                            <Expander Header="Trackpad profile"
                                      IsExpanded="{Binding IsTrackpadExpanded, Mode=TwoWay}"
                                      Expanded="OnTrackpadExpanded"
                                      Style="{DynamicResource PreferencesNestedAccordionStyle}">
                                <ui:SpacingStackPanel Spacing="{DynamicResource SpaceSm}">
                                    <TextBlock Text="Pointer speed override"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock Text="{Binding PointerSpeedHint}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider
                                                Minimum="10"
                                                Maximum="100"
                                                TickFrequency="5"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding PointerSpeed, Mode=TwoWay}"
                                                Style="{DynamicResource ModernSliderStyle}" />
                                        <TextBlock Text="{Binding PointerSpeed, StringFormat={}{0}%}"
                                                   Grid.Column="1"
                                                   MinWidth="48"
                                                   Margin="{DynamicResource InsetSm}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextBrush}" />
                                    </Grid>
                                    <ui:SpacingStackPanel Orientation="Horizontal"
                                                          Spacing="{DynamicResource SpaceSm}">
                                        <Button Content="Save speed"
                                                Style="{DynamicResource PrimaryButtonStyle}"
                                                Click="OnSavePointerSpeed" />
                                        <Button Content="Use global"
                                                Click="OnUseGlobalPointerSpeed" />
                                    </ui:SpacingStackPanel>
                                </ui:SpacingStackPanel>
                            </Expander>
                            <Expander Header="Permissions"
                                      IsExpanded="{Binding IsPermissionsExpanded, Mode=TwoWay}"
                                      Expanded="OnPermissionsExpanded"
                                      Style="{DynamicResource PreferencesNestedAccordionStyle}">
                                <ItemsControl ItemsSource="{Binding Permissions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ui:SpacingWrapPanel HorizontalSpacing="{DynamicResource SpaceSm}"
                                                                 VerticalSpacing="{DynamicResource SpaceSm}" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="390"
                                                    Padding="14"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{DynamicResource RadiusMedium}">
                                                <ui:SpacingStackPanel Spacing="{DynamicResource SpaceSm}">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               TextWrapping="Wrap" />
                                                    <ui:SpacingWrapPanel HorizontalSpacing="{DynamicResource SpaceXs}"
                                                                         VerticalSpacing="{DynamicResource SpaceXs}">
                                                        <Button Content="{Binding UseGlobalLabel}"
                                                                Width="{StaticResource PermissionChoiceButtonWidth}"
                                                                Tag="{Binding UseGlobalVisualState}"
                                                                Style="{DynamicResource ChoiceStateButtonStyle}"
                                                                Click="OnUseGlobalPermission" />
                                                        <Button Content="{Binding AllowLabel}"
                                                                Width="{StaticResource PermissionChoiceButtonWidth}"
                                                                Tag="{Binding AllowVisualState}"
                                                                Style="{DynamicResource ChoiceStateButtonStyle}"
                                                                Click="OnAllowPermission" />
                                                        <Button Content="{Binding BlockLabel}"
                                                                Width="{StaticResource PermissionChoiceButtonWidth}"
                                                                Tag="{Binding BlockVisualState}"
                                                                Style="{DynamicResource ChoiceStateButtonStyle}"
                                                                Click="OnBlockPermission" />
                                                    </ui:SpacingWrapPanel>
                                                </ui:SpacingStackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </ui:SpacingStackPanel>
                    </Expander>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ui:SpacingStackPanel Grid.Row="2"
                              Orientation="Horizontal"
                              Spacing="{DynamicResource SpaceSm}">
            <Button x:Name="CleanUpDuplicatesButton" Content="Clean up duplicates" />
            <Button x:Name="RemoveDeviceButton"
                    Content="Remove"
                    IsEnabled="False"
                    Style="{DynamicResource DangerButtonStyle}"
                    Click="OnRemoveDevice" />
            <Button x:Name="RemoveAllButton"
                    Content="Remove all"
                    Style="{DynamicResource DangerButtonStyle}" />
        </ui:SpacingStackPanel>
    </Grid>
</UserControl>
