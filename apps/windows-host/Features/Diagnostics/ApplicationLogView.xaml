<UserControl x:Class="VolturaAir.Host.Features.Diagnostics.ApplicationLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:VolturaAir.Host.Ui">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="{DynamicResource GridSpaceMd}" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="LogScroller"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ui:SpacingStackPanel Spacing="{DynamicResource SpaceMd}">
                <TextBlock Text="Application log"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" />
                <TextBlock Text="Filter the newest 250 sanitized remote-command and Windows-host activity entries."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <CheckBox x:Name="LoggingToggle"
                          HorizontalAlignment="Left"
                          Content="Write application log" />
                <ui:SpacingWrapPanel x:Name="FiltersPanel"
                                     HorizontalSpacing="{DynamicResource SpaceSm}"
                                     VerticalSpacing="{DynamicResource SpaceSm}">
                    <Button x:Name="ClearFiltersButton"
                            VerticalAlignment="Bottom"
                            AutomationProperties.Name="Clear filters"
                            Style="{DynamicResource CompactIconButtonStyle}"
                            ToolTip="Clear filters">
                        <Grid Width="16" Height="16">
                            <Path Data="M 3,3 L 13,13"
                                  Stroke="{DynamicResource TextBrush}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                            <Path Data="M 13,3 L 3,13"
                                  Stroke="{DynamicResource TextBrush}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Grid>
                    </Button>
                </ui:SpacingWrapPanel>
                <Border Padding="{DynamicResource InsetMd}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}">
                    <TextBlock x:Name="StatusText"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedTextBrush}" />
                </Border>
                <Border Padding="{DynamicResource InsetSm}"
                        Background="{DynamicResource WindowBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}">
                    <ui:SpacingStackPanel x:Name="LogRows"
                                          Spacing="{DynamicResource SpaceSm}" />
                </Border>
            </ui:SpacingStackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="{DynamicResource GridSpaceXl}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="RefreshButton"
                    Content="Refresh"
                    VerticalAlignment="Top" />
            <ui:SpacingWrapPanel Grid.Column="2"
                                 HorizontalSpacing="{DynamicResource SpaceLg}"
                                 VerticalSpacing="{DynamicResource SpaceSm}">
                <ui:SpacingWrapPanel HorizontalSpacing="{DynamicResource SpaceSm}"
                                     VerticalSpacing="{DynamicResource SpaceSm}">
                    <Button x:Name="CopyButton" Content="Copy filtered log" />
                    <Button x:Name="OpenFolderButton" Content="Open log folder" />
                </ui:SpacingWrapPanel>
                <Button x:Name="DeleteButton"
                        Content="Delete logs"
                        Style="{DynamicResource DangerButtonStyle}" />
                <CheckBox x:Name="AutomaticRefreshToggle"
                          VerticalAlignment="Center"
                          Content="Automatic log refresh" />
            </ui:SpacingWrapPanel>
        </Grid>
    </Grid>
</UserControl>
