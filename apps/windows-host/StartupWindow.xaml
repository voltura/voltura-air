<Window x:Class="VolturaAir.Host.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:VolturaAir.Host.Ui"
        Title="Voltura Air"
        Width="520"
        Height="360"
        MinWidth="420"
        MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{DynamicResource WindowBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Generated/UiTokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{DynamicResource Inset3xl}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{DynamicResource GridSpaceXl}" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{DynamicResource GridSpaceMd}" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="96"
                Height="96"
                CornerRadius="24"
                HorizontalAlignment="Center"
                Background="Transparent">
            <Image x:Name="StartupAppImage"
                   Width="96"
                   Height="96"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
        </Border>

        <TextBlock Grid.Row="3"
                   Text="Voltura Air"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}"
                   HorizontalAlignment="Center" />

        <ui:SpacingStackPanel Grid.Row="5" Spacing="{DynamicResource SpaceLg}">
            <ui:SpacingStackPanel x:Name="StartupProgressState" Spacing="{DynamicResource SpaceLg}">
                <TextBlock x:Name="StatusText"
                           Text="Starting connection services."
                           FontSize="15"
                           Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Center" />
                <ProgressBar x:Name="StartupProgress"
                             MaxWidth="288"
                             Height="6"
                             IsIndeterminate="True" />
            </ui:SpacingStackPanel>
            <TextBlock x:Name="ErrorText"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Visibility="Collapsed"
                       Foreground="{DynamicResource DangerBrush}" />
            <ui:SpacingStackPanel x:Name="ErrorActions"
                                  Orientation="Horizontal"
                                  HorizontalAlignment="Center"
                                  Spacing="{DynamicResource SpaceSm}"
                                  Visibility="Collapsed">
                <Button x:Name="CopyDetailsButton"
                        Content="Copy details"
                        MinWidth="120"
                        Height="38"
                        Click="OnCopyDetailsClicked" />
                <Button Content="Close"
                        MinWidth="120"
                        Height="38"
                        Click="OnCloseClicked" />
            </ui:SpacingStackPanel>
        </ui:SpacingStackPanel>
    </Grid>
</Window>
