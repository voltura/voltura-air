<Window x:Class="VolturaAir.Host.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voltura Air"
        Width="520"
        Height="360"
        MinWidth="420"
        MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{DynamicResource WindowBrush}">
    <Grid Margin="44">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="96"
                Height="96"
                CornerRadius="24"
                HorizontalAlignment="Center"
                Background="{DynamicResource AccentBrush}">
            <TextBlock Text="VA"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

        <TextBlock Grid.Row="2"
                   Text="Voltura Air"
                   Margin="0,24,0,0"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}"
                   HorizontalAlignment="Center" />

        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText"
                       Text="Starting connection services."
                       FontSize="15"
                       Foreground="{DynamicResource MutedTextBrush}"
                       HorizontalAlignment="Center" />
            <ProgressBar x:Name="StartupProgress"
                         Margin="72,22,72,0"
                         Height="6"
                         IsIndeterminate="True" />
            <TextBlock x:Name="ErrorText"
                       Margin="0,18,0,0"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Visibility="Collapsed"
                       Foreground="{DynamicResource DangerBrush}" />
            <StackPanel x:Name="ErrorActions"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,18,0,0"
                        Visibility="Collapsed">
                <Button x:Name="CopyDetailsButton"
                        Content="Copy details"
                        MinWidth="120"
                        Height="38"
                        Margin="0,0,8,0"
                        Click="OnCopyDetailsClicked" />
                <Button Content="Close"
                        MinWidth="120"
                        Height="38"
                        Click="OnCloseClicked" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
