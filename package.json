{
  "name": "voltura-air",
  "private": true,
  "version": "0.7.4",
  "license": "MIT",
  "workspaces": [
    "apps/mobile-web"
  ],
  "scripts": {
    "actions:restore": "node scripts/restore-github-actions.mjs",
    "ai:init": "npm run ai:update && npm run ai:schedule:create && npm run ai:shortcut:create",
    "ai:schedule:create": "node scripts/ai-schedule.mjs",
    "ai:schedule:remove": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/remove-chatgpt-codex-schedule.ps1",
    "ai:shortcut:create": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-chatgpt-codex-shortcut.ps1",
    "ai:shortcut:remove": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/remove-chatgpt-codex-shortcut.ps1",
    "ai:update": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-chatgpt-codex.ps1",
    "branch:sync": "node scripts/sync-branch.mjs",
    "build": "npm run ui:tokens:check && npm run build --workspace apps/mobile-web && dotnet build VolturaAir.slnx",
    "branding:generate": "npm run icons:generate && npm run screenshots:site",
    "cache:purge": "node scripts/purge-windows-icon-cache.mjs",
    "clean:git": "git gc --prune=now",
    "clean:temp": "git clean -fdX -e !/.vs/ -e !/.vs/** -e !/.vscode/settings.json",
    "clean:temp:preview": "git clean -ndX -e !/.vs/ -e !/.vs/** -e !/.vscode/settings.json",
    "code:statistics": "node scripts/code-statistics.mjs",
    "deps:update": "npm update",
    "docs:check": "node scripts/check-documentation-map.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "host:ownership:check": "node scripts/check-host-partial-ownership.mjs",
    "help": "node scripts/command-help.mjs",
    "lint": "npm run lint --workspace apps/mobile-web",
    "maintenance:full": "npm run cache:purge && npm run clean:temp && npm run clean:git && npm run deps:update",
    "dev": "node scripts/dev.mjs",
    "dev:quick": "node scripts/dev.mjs --quick",
    "dev:bare-source": "npm run package:source:bare",
    "dev:host": "node scripts/dev-host.mjs",
    "dev:source": "npm run package:source",
    "dev:ui": "node scripts/dev-ui-with-devices.mjs",
    "dev:web": "npm run dev --workspace apps/mobile-web",
    "package:source": "powershell -ExecutionPolicy Bypass -File scripts/zip-clean-repo.ps1",
    "package:source:bare": "powershell -ExecutionPolicy Bypass -File scripts/zip-clean-repo.ps1 -Bare",
    "package:win": "powershell -ExecutionPolicy Bypass -File scripts/package-win.ps1",
    "package:win:small": "powershell -ExecutionPolicy Bypass -File scripts/package-win.ps1 -FrameworkDependentOnly",
    "package:win:test": "powershell -ExecutionPolicy Bypass -File scripts/package-win.ps1 -NoInstallerCompression",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-release.ps1",
    "release:bump": "node scripts/bump-release.mjs",
    "release:full": "node scripts/release-full.mjs",
    "release:local": "node scripts/release-local.mjs",
    "release:sync-release-notes": "node scripts/sync-release-notes.mjs",
    "screenshots:site": "node scripts/capture-site-screenshots.mjs",
    "publish:site": "node scripts/publish-site.mjs",
    "publish:site:list": "node scripts/publish-site.mjs --list",
    "publish:site:password": "node scripts/publish-site.mjs --store-password",
    "publish:site:password:clear": "node scripts/publish-site.mjs --clear-password",
    "size:report": "node scripts/report-source-sizes.mjs",
    "size:check": "node scripts/report-source-sizes.mjs --check",
    "test": "npm run docs:check && npm run ui:tokens:check && npm run size:check && npm run host:ownership:check && npm run test --workspace apps/mobile-web -- --run && npm run test:scripts && dotnet test VolturaAir.slnx",
    "test:web": "npm run test --workspace apps/mobile-web -- --run",
    "test:host": "dotnet test VolturaAir.slnx",
    "test:scripts": "node --test tests/scripts/*.test.mjs",
    "test:ui": "node scripts/dev-ui-with-devices.mjs --smoke-test",
    "ui:tokens:check": "node scripts/generate-ui-tokens.mjs --check",
    "ui:tokens:generate": "node scripts/generate-ui-tokens.mjs"
  },
  "devDependencies": {
    "sharp": "^0.35.3",
    "ssh2-sftp-client": "^12.1.1"
  },
  "allowScripts": {
    "ssh2@1.17.0": true,
    "unrs-resolver@1.12.2": true
  }
}
