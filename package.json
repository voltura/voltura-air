{
  "name": "voltura-air",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "workspaces": [
    "apps/mobile-web"
  ],
  "scripts": {
    "build": "npm run build --workspace apps/mobile-web && dotnet build VolturaAir.slnx",
    "dev": "node scripts/dev.mjs",
    "dev:host": "node scripts/dev-host.mjs",
    "dev:web": "npm run dev --workspace apps/mobile-web",
    "package:win": "powershell -ExecutionPolicy Bypass -File scripts/package-win.ps1",
    "screenshots:site": "node scripts/capture-site-screenshots.mjs",
    "test": "npm run test --workspace apps/mobile-web -- --run && dotnet test VolturaAir.slnx",
    "test:web": "npm run test --workspace apps/mobile-web -- --run",
    "test:host": "dotnet test VolturaAir.slnx"
  }
}
