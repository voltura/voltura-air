{
  "name": "voltura-air",
  "private": true,
  "version": "0.3.0",
  "license": "MIT",
  "workspaces": [
    "apps/mobile-web"
  ],
  "scripts": {
    "build": "npm run build --workspace apps/mobile-web && dotnet build VolturaAir.slnx",
    "dev": "node scripts/dev.mjs",
    "dev:bare-source": "npm run package:source:bare",
    "dev:host": "node scripts/dev-host.mjs",
    "dev:source": "npm run package:source",
    "dev:ui": "node scripts/dev-ui-with-devices.mjs",
    "dev:web": "npm run dev --workspace apps/mobile-web",
    "package:source": "powershell -ExecutionPolicy Bypass -File scripts/zip-clean-repo.ps1",
    "package:source:bare": "powershell -ExecutionPolicy Bypass -File scripts/zip-clean-repo.ps1 -Bare",
    "package:win": "powershell -ExecutionPolicy Bypass -File scripts/package-win.ps1",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-release.ps1",
    "screenshots:site": "node scripts/capture-site-screenshots.mjs",
    "size:report": "node scripts/report-source-sizes.mjs",
    "test": "npm run test --workspace apps/mobile-web -- --run && dotnet test VolturaAir.slnx",
    "test:web": "npm run test --workspace apps/mobile-web -- --run",
    "test:host": "dotnet test VolturaAir.slnx",
    "test:ui": "node scripts/dev-ui-with-devices.mjs --smoke-test"
  }
}
